# Gere uma com: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your-secret-key-here

# Ativa o modo de depuração. Use True em desenvolvimento e False em produção.
DEBUG=True

# Nome do banco de dados
DB_NAME=cinereserve

# Usuário do banco de dados
DB_USER=postgres

# Senha do banco de dados
DB_PASSWORD=postgres

# Host do banco de dados.
# Use "db" ao rodar com Docker Compose, ou "localhost" para rodar localmente.
DB_HOST=db

# Porta do banco de dados. O padrão do PostgreSQL é 5432.
DB_PORT=5432
